          <ld>int (*compar)(const struct dirent **, const struct dirent **)</ld>
          <ll>)</ll>
        </pt>
        <par name="dir">directory to be scanned</par>
        <par name="namelist">list in which selected entries are stored</par>
        <par name="sel">function to select directory entries</par>
        <par name="compar">function to sort directory entries</par>
        <return>
          <rc cond="success">number of entries stored</rc>
          <rc cond="failure">-1</rc>
        </return>
