  <libfun lib="so_functions" name="strtok_r">
    <documentation>
      <desc>split string into tokens</desc>
      <apidoc>
        <pt>
          <ll>char *strtok_r(</ll>
          <ld>char *restrict s</ld>
          <ld>const char *restrict sep</ld>
          <ld>char **restrict state</ld>
          <ll>)</ll>
        </pt>
        <par name="s">string to be split</par>
        <par name="sep">delimiter used for splitting</par>
        <par name="state">user-provided pointer to maintain state</par>
        <return>
          <rc cond="success">pointer to the first byte of a token</rc>
          <rc cond="failure">NULL </rc>
        </return>
      </apidoc>
    </documentation>
    <api adj="0" cc="cdecl" name="strtok_r">
      <par loc="stack" name="s" nr="1">
        <type><ptr>char</ptr></type>
