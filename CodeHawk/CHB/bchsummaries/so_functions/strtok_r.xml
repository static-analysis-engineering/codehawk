        <pre><deref-read-nt/></pre>
      </par>
      <par loc="stack" name="state" nr="3">
        <type><ptr><ptr>char</ptr></ptr></type>
        <pre><deref-read-write/></pre>
      </par>
      <returntype><ptr>char</ptr></returntype>
    </api>
